{
  "name": "http-switcher",
  "version": "1.0.0",
  "description": "HTTP Switcher — HTTP 请求中转服务",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop http-switcher",
    "pm2:restart": "pm2 restart http-switcher",
    "pm2:logs": "pm2 logs http-switcher",
    "docker:build": "docker build -t http-switcher .",
    "docker:run": "docker run -d -p 8080:8080 --env-file .env http-switcher",
    "test": "node src/test.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}
